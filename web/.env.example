# WebSocket signaling server URL
NEXT_PUBLIC_SIGNALING_URL=ws://localhost:8080

# STUN server (default: Google's public STUN)
NEXT_PUBLIC_STUN_URL=stun:stun.l.google.com:19302

# TURN server (optional - set for NAT traversal in restricted networks)
# NEXT_PUBLIC_TURN_URL=turn:your-turn-server.example.com:3478
# NEXT_PUBLIC_TURN_USERNAME=your-username
# NEXT_PUBLIC_TURN_CREDENTIAL=your-credential
